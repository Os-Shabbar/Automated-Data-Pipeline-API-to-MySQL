# ============================================================
# Environment variables for Anonymized Kobo/API to MySQL ETL
# Copy this file to .env and replace placeholder values locally.
# Do NOT commit your real .env file to GitHub.
# ============================================================

# -----------------------------
# MySQL Database Configuration
# -----------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_username
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=your_database_name

# -----------------------------
# API / KoboToolbox Configuration
# -----------------------------
KOBO_BASE_URL=https://kf.kobotoolbox.org/api/v2/assets/
KOBO_API_TOKEN=your_api_token_here

# Source form / project identifiers
PROJECT_UID_1=your_first_project_uid
PROJECT_UID_2=your_second_project_uid
PROJECT_UID_3=your_third_project_uid

# -----------------------------
# Optional Runtime Settings
# -----------------------------
LOG_LEVEL=INFO
API_TIMEOUT_SECONDS=30
MAX_WORKERS=3
