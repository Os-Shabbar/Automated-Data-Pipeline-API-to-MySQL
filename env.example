# ============================================================

# Environment variables for Anonymized Kobo/API to SQL Server ETL

# Copy this file to .env and replace placeholder values locally.

# Do NOT commit your real .env file to GitHub.

# ============================================================

# -----------------------------

# SQL Server Database Configuration

# -----------------------------

LOAD_TO_SQLSERVER=true

SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_USER=your_sqlserver_username
SQLSERVER_PASSWORD=your_sqlserver_password
SQLSERVER_DB=your_database_name
SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server

# -----------------------------

# API / KoboToolbox Configuration

# -----------------------------

KOBO_BASE_URL=https://kf.kobotoolbox.org/api/v2/assets/
KOBO_API_TOKEN=your_api_token_here

# Source form / project identifiers

KOBO_PROJECT_UID_1=your_first_project_uid
KOBO_PROJECT_UID_2=your_second_project_uid
KOBO_PROJECT_UID_3=your_third_project_uid

# -----------------------------

# Optional Runtime Settings

# -----------------------------

REQUEST_TIMEOUT_SECONDS=30
MAX_WORKERS=3
ANONYMIZE_GEOLOCATION=true

# Hash salt should be changed locally and kept private.

# Do NOT commit your real salt to GitHub.

HASH_SALT=replace_with_a_private_random_salt
